<theme>
<formatVersion>4</formatVersion>


<view name="system">

	<image name="art" extra="true">
		<path>./../assets/arts/$system.jpg</path>
		<size>1 1</size>
		<pos>0 0</pos>
		<origin>0 0</origin>
	</image> 	

	<carousel name="systemcarousel">
		<type>vertical</type>
		<pos>0 0</pos>
		<size>1 1</size>
		<origin>0 0</origin>
		<color>00000000</color>
		<logoScale>1.3</logoScale>
		<logoSize>0.2 0.2</logoSize>
		<logoAlignment>right</logoAlignment>
		<maxLogoCount>6</maxLogoCount>

	</carousel>

	<text name="systemInfo">
		<fontPath>./../assets/Roboto-Medium.ttf</fontPath>
		<pos>0 0.95</pos>
		<size>0.98 0.05</size>
		<fontSize>0.026</fontSize>
		<alignment>right</alignment>
		<zIndex>71</zIndex>
	</text>


	<helpsystem name="help">
		<fontPath>./../assets/Superstar X.ttf</fontPath>
		<fontSize>0.028</fontSize>
		<pos>0.05 0.94</pos>
	</helpsystem>
  
</view>

</theme>