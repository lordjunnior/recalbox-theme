	<text name="md_players">
		<pos>0.845 0.78</pos>
	</text>		

	<text name="md_lbl_lastplayed">
		<pos>0.830 0.80</pos>
	</text>
	<datetime name="md_lastplayed">
		<pos>0.845 0.82</pos>
	</datetime>
	
	<text name="md_lbl_playcount">
		<pos>0.830 0.84</pos>
	</text>
	<text name="md_playcount">
