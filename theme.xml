<theme>
<formatVersion>4</formatVersion>

<include>./config.xml</include>

<view name="menu">
	<menuText name="menufooter">
		<fontPath>./assets/Superstar X.ttf</fontPath>
			<fontSize>0.025</fontSize>
			<color>808080FF</color>
	</menuText>
	<menuText name="menutext">
		<fontPath>./assets/Exo2-BoldCondensed.otf</fontPath>
			<fontSize>0.035</fontSize>
			<color>35495EFF</color>
			<separatorColor>35495EFF</separatorColor>
			<selectorColor>35495EFF</selectorColor>
			<selectedColor>FFFFFFCC</selectedColor>
	</menuText>
	<menuTextSmall name="menutextsmall">
		<fontPath>./assets/Roboto-Medium.ttf</fontPath>
			<fontSize>0.028</fontSize>
			<color>35495EFF</color>
	</menuTextSmall>
	<menuText name="menutitle">
		<fontPath>./assets/Superstar X.ttf</fontPath>
			<fontSize>0.044</fontSize>
			<color>6b9bce</color>
	</menuText>
	<menuBackground name="menubg">
		<color>F1F1F1CC</color>
		<path>./assets/borderframe.png</path>
		<fadePath>./assets/fade.png</fadePath>
	</menuBackground>
			<menuIcons name="menuicons">
			<iconKodi>./assets/menu_icons/Kodi.png</iconKodi>
			<iconSystem>./assets/menu_icons/System.png</iconSystem>
			<iconUpdates>./assets/menu_icons/Updates.png</iconUpdates>
			<iconGames>./assets/menu_icons/Games.png</iconGames>
			<iconControllers>./assets/menu_icons/Controllers.png</iconControllers>
			<iconUI>./assets/menu_icons/UI.png</iconUI>
			<iconSound>./assets/menu_icons/Sound.png</iconSound>
			<iconNetwork>./assets/menu_icons/Network.png</iconNetwork>
			<iconScraper>./assets/menu_icons/Scraper.png</iconScraper>
			<iconAdvanced>./assets/menu_icons/Advanced.png</iconAdvanced>
			<iconQuit>./assets/menu_icons/Quit.png</iconQuit>
			<iconRestart>./assets/menu_icons/Restart.png</iconRestart>
			<iconShutdown>./assets/menu_icons/Shutdown.png</iconShutdown>
			<iconFastShutdown>./assets/menu_icons/Fastshutdown.png</iconFastShutdown>			
		</menuIcons>
	<helpsystem name="help">
		<fontPath>./assets/Superstar X.ttf</fontPath>
		<fontSize>0.028</fontSize>
		<pos>0.255 0.94</pos>
	</helpsystem>
</view>

<view name="system, basic, detailed">

	<image name="background" extra="true">
		<tile>true</tile>
		<path>./assets/square.png</path>
		<size>1 1</size>
		<pos>0 0</pos>
		<origin>0 0</origin>
	</image>
	
	<image name="logo">
		<path>./assets/logos/$system.png</path>
	</image>

		<sound name="bgsound">
	    <path>./assets/sounds/$system.ogg</path>
	</sound>
</view>



<!-- Gamelist View -->

<view name="basic">
	 
	<image name="bg3" extra="true">
		<tile>false</tile>
		<path>./assets/gamelist.png</path>
		<origin>0.5 0.5</origin>
		<size>0.5 0.8</size>
		<pos>0.5 0.5</pos>
	</image>

	<image name="logo">
		<origin>0.5 0.5</origin>
		<pos>0.125 0.5</pos>
		<maxSize>0.185 0.185</maxSize>
	</image>
	 
	<textlist name="gamelist">
		<selectorImagePath>./assets/icon.png</selectorImagePath>
		<selectorHeight>.05</selectorHeight>
		<fontPath>./assets/Roboto-Medium.ttf</fontPath>
		<alignment>left</alignment>
		<forceUppercase>1</forceUppercase>
		<pos>0.3 0.165</pos>
		<size>0.4 0.68</size>
		<fontSize>0.03</fontSize>
		<lineSpacing>1.49</lineSpacing>
		<horizontalMargin>0.05</horizontalMargin>
	</textlist>

	<helpsystem name="help">
		<fontPath>./assets/Roboto-Medium.ttf</fontPath>
		<fontSize>0.023</fontSize>
		<pos>0.05 0.94</pos>
	</helpsystem>
	
</view>

<view name="detailed">
	 
	<image name="bg2" extra="true">
		<tile>true</tile>
		<path>./assets/square.png</path>
		<size>0.9 0.86</size>
		<pos>0.05 0.07</pos>
	</image>

	<image name="logo">
		<path>./assets/logos2/$system.svg</path>
	</image>
	
	<image name="bg3" extra="true">
		<tile>false</tile>
		<path>./assets/gamelist.png</path>
		<size>0.348 0.9</size>
		<pos>0.093 0.046</pos>
	</image>

	<image name="logo">
		<origin>0.5 0.5</origin>
		<pos>0.555 0.825</pos>
		<maxSize>0.185 0.185</maxSize>
	</image>



	<image name="md_image">
		<origin>0.5 0.5</origin>
		<pos>0.7 0.4</pos>
		<maxSize>0.51 0.51</maxSize>
	</image>
	 
	<textlist name="gamelist">
		<selectorImagePath>./assets/icon.png</selectorImagePath>
		<selectorHeight>.05</selectorHeight>
		<fontPath>./assets/Exo2-BoldCondensed.otf</fontPath>
		<alignment>left</alignment>
		<forceUppercase>1</forceUppercase>
		<pos>0.07 0.122</pos>
		<size>0.34 0.75</size>
		<fontSize>0.03</fontSize>
		<lineSpacing>1.675</lineSpacing>
		<horizontalMargin>0.05</horizontalMargin>
	</textlist>

	<helpsystem name="help">
		<fontPath>./assets/Superstar X.ttf</fontPath>
		<fontSize>0.021</fontSize>
		<pos>0.445 0.94</pos>
	</helpsystem>
	
	<datetime name="md_releasedate, md_lastplayed">
		<forceUppercase>1</forceUppercase>
		<fontPath>./assets/Exo2-Bold.ttf</fontPath>
		<fontSize>0.02</fontSize>
		<size>0 0.02</size>
	</datetime>
		
	<text name="md_lbl_releasedate, md_lbl_developer, md_lbl_publisher, md_lbl_genre, md_lbl_players, md_lbl_lastplayed, md_lbl_playcount, md_lbl_favorite, md_developer, md_publisher, md_genre, md_players, md_playcount, md_favorite">
		<forceUppercase>1</forceUppercase>
		<fontPath>./assets/Exo2-BoldCondensed.otf</fontPath>
		<fontSize>0.02</fontSize>
		<size>0.144 0.02</size>
	</text>
	
	<text name="md_lbl_releasedate">
		<pos>0.675 0.76</pos>
	</text>		
	<datetime name="md_releasedate">
		<pos>0.69 0.78</pos>			
	</datetime>		
		
	<text name="md_lbl_developer">
